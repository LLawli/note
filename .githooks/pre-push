#!/usr/bin/env bash
# Pre-push gate — run the full workspace test suite before publishing commits.
# Formatting and lints are already enforced by the pre-commit hook.
# Emergency bypass: `git push --no-verify`.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "→ cargo test --workspace"
if ! cargo test --workspace; then
  echo >&2
  echo "✗ pre-push blocked: tests failed." >&2
  exit 1
fi

echo "✓ pre-push tests passed"
